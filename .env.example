# --- Frontend (apps/web) ---
# Project URL (Vercel)
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Supabase (Production Project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API Configuration
# Option 1: If using Next.js API Routes (in apps/web/app/api)
NEXT_PUBLIC_API_URL=/api

# Option 2: If using standalone Backend (Railway/Render)
# NEXT_PUBLIC_API_URL=https://your-backend-api.up.railway.app

# AI Service Config
# Point to Python service or leave empty to trigger fallback logic
NEXT_PUBLIC_AI_SERVICE_URL=https://your-python-service.onrender.com
# Set to 'true' to force mock mode in production if AI service is not deployed
NEXT_PUBLIC_FORCE_MOCK_AI=false


# --- Backend (apps/api) ---
# Only needed if deploying standalone Node/Fastify app
DATABASE_URL="postgres://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgres://user:password@host:5432/postgres"

# AI Service Internal URL
AI_SERVICE_URL=http://localhost:8000
